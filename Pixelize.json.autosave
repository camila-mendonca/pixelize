"},"parameters":["rectangle","=","255"]},{"type":{"value":"PrimitiveDrawing::OutlineSize"},"parameters":["rectangle","=","0"]},{"type":{"value":"SetBooleanObjectVariable"},"parameters":["rectangle","isColorRight","True",""]},{"type":{"value":"SetNumberVariable"},"parameters":["finishedPixels","+","1"]}],"events":[{"type":"BuiltinCommonInstructions::Standard","conditions":[{"type":{"value":"LinkedObjects::PickObjectsLinkedTo"},"parameters":["","colorID","rectangle",""]}],"actions":[{"type":{"value":"Delete"},"parameters":["colorID",""]}]},{"type":"BuiltinCommonInstructions::JsCode","inlineCode":["const colorList = runtimeScene.getVariables().get(\"currentLevel\").getChild(\"colorList\");","const clickedColor = runtimeScene.getVariables().get(\"clickedColor\").getAsNumber();","const currentColor = colorList.getChild(clickedColor-1);//Why does it need to be -1?","const index = currentColor.getChild(\"id\").getAsNumber(); //since colorList is a structure, I can't have indexed access to the items (boo), but since the ids are set in sequenced order, I can access the next color on the list by adding 1 to the current color id","console.log(\"Color index: \" + index);","currentColor.getChild(\"paintedCount\").setNumber(currentColor.getChild(\"paintedCount\").getAsNumber()+1);","const paintedCount = currentColor.getChild(\"paintedCount\").getAsNumber();","const count = currentColor.getChild(\"count\").getAsNumber();","","  // 1. Try to select the next unfinished item (forward)","  //Sooooo, I'll need to access the child by its key value (id), and in order to check if it is the last child of the structure, I need to see if the id is the same as the lenght of the structure. Doamne ajuta"," ","if (paintedCount==count){","  for (let i = index; i < colorList.getChildrenCount(); i++) {","    if(checkNextColor(i)){","      return;","    }    ","  }  ","","  // 2. If none forward, go backwards","  for (let i = index - 1; i >= 0; i--) {","    if(checkNextColor(i)){","      return;","    }","  }","} //if paintedCount","  ","function checkNextColor(indexToCheck){","  let nextColor = colorList.getChild(indexToCheck);","      if (nextColor.getChild(\"paintedCount\").getAsNumber() != nextColor.getChild(\"count\").getAsNumber()) {","        const newColor = runtimeScene.getVariables().get(\"clickedColor\");","        const newHex = runtimeScene.getVariables().get(\"clickedColorHex\");","        newColor.setNumber(nextColor.getChild(\"id\").getAsNumber());","        newHex.setString(nextColor.getChild(\"hex\").getAsString());","        console.log(\"Next color selected: \" + nextColor.getChild(\"id\").getAsNumber());","","        const palette = runtimeScene.getObjects(\"paletteBlock\");","        const nextPalette = palette[indexToCheck-1];","        const availableVariable = nextPalette.getVariables().get(\"available\");","        availableVariable.setBoolean(false);","","        return true;","  }","} //checkNextColor",""],"parameterObjects":"","useStrict":true,"eventsSheetExpanded":false}]},{"type":"BuiltinCommonInstructions::Standard","conditions":[],"actions":[{"type":{"value":"PrimitiveDrawing::Rectangle"},"parameters":["rectangle","0","0","pixel.size","pixel.size"]}]}]}],"layers":[{"ambientLightColorB":200,"ambientLightColorG":200,"ambientLightColorR":200,"camera2DPlaneMaxDrawingDistance":5000.0,"camera3DFarPlaneDistance":10000.0,"camera3DFieldOfView":45.0,"camera3DNearPlaneDistance":3.0,"cameraType":"","followBaseLayerCamera":false,"isLightingLayer":false,"isLocked":false,"name":"","renderingType":"","visibility":true,"cameras":[{"defaultSize":true,"defaultViewport":true,"height":0.0,"viewportBottom":1.0,"viewportLeft":0.0,"viewportRight":1.0,"viewportTop":0.0,"width":0.0}],"effects":[{"effectType":"Scene3D::HemisphereLight","name":"3D Light","doubleParameters":{"elevation":45.0,"intensity":1.0,"rotation":0.0},"stringParameters":{"groundColor":"64;64;64","skyColor":"255;255;255","top":"Y-"},"booleanParameters":{}}]},{"ambientLightColorB":200,"